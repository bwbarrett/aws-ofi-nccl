Name: aws-ofi-nccl
Version: @VERSION@
Release: 1
Summary: NCCL network plugin to support Libfabric devices

Group: Development/Libraries
License: Apache-2.0
Url: http://www.github.com/aws/aws-ofi-nccl
Source: http://www.github.org/aws/aws-ofi-nccl/releases/download/v{%version}/aws-ofi-nccl-%{version}.tar.bz2

%description
The aws-ofi-nccl package provides a NCCL network plugin to support
Libfabric devices, such as EFA or CXI.  The plugin supports most
providers with RDM support and works with NCCL 2.4.0 or later.


%prep
%setup -q -n %{name}-%{version}

%build
%configure %{configopts}
make %{?_smp_mflags}

%install
rm -rf %{buildroot}

%make_install
# remove unpackaged files from the buildroot
rm -f %{buildroot}%{_libdir}/*.la

%clean
rm -rf %{buildroot}

%files
%defattr(-, root, root, -)
%{_libdir}/lib*.so.*
%doc AUTHORS COPYING README

%changelog
